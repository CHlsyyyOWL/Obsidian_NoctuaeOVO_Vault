{
  "database": "Zotero",
  "noteImportFolder": "Study/Noctuae Celsum/Article Notes",
  "pdfExportImageDPI": 120,
  "pdfExportImageFormat": "jpg",
  "pdfExportImageQuality": 90,
  "citeFormats": [
    {
      "name": "Zotero Insert URL",
      "format": "template",
      "template": "[{{title}}]({{desktopURI}})"
    }
  ],
  "exportFormats": [
    {
      "name": "Zotero_Imports2",
      "outputPathTemplate": "Study/Academic/{{citekey}}.md",
      "imageOutputPathTemplate": "{{citekey}}/",
      "imageBaseNameTemplate": "image",
      "templatePath": "Vault Tool Box/Templates/Tp_Article.md",
      "cslStyle": "chicago-note-bibliography"
    }
  ],
  "citeSuggestTemplate": "[[{{citekey}}]]",
  "openNoteAfterImport": true,
  "whichNotesToOpenAfterImport": "first-imported-note"
}